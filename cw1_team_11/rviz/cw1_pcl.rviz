      G: 0.5
      B: 0.0
    Enabled: true
    Name: Plane
    Queue Size: 10
    Selectable: true
    Size (Pixels): 2
    Style: Points
    Topic: /cw1_cloud/cloud_plane
    Unreliable: false
    Value: true
  - Alpha: 1
    Class: rviz_default_plugins/PointCloud2
    Color Transformer: FlatColor
    Flat Color:
      R: 1.0
      G: 0.0
      B: 0.0
    Enabled: true
    Name: Cluster 1
    Queue Size: 10
    Selectable: true
    Size (Pixels): 3
    Style: Points
    Topic: /cw1_cloud/cloud_cluster1
    Unreliable: false
    Value: true
  - Alpha: 1
    Class: rviz_default_plugins/PointCloud2
    Color Transformer: FlatColor
    Flat Color:
      R: 1.0
      G: 0.0
      B: 1.0
    Enabled: true
    Name: Cluster 2
    Queue Size: 10
    Selectable: true
    Size (Pixels): 3
    Style: Points
    Topic: /cw1_cloud/cloud_cluster2
    Unreliable: false
    Value: true
  - Alpha: 1
    Class: rviz_default_plugins/PointCloud2
    Color Transformer: FlatColor
    Flat Color:
      R: 1.0
      G: 1.0
      B: 0.0
    Enabled: true
    Name: Cluster 3
    Queue Size: 10
    Selectable: true
    Size (Pixels): 3
    Style: Points
    Topic: /cw1_cloud/cloud_cluster3
    Unreliable: false
    Value: true
  - Alpha: 1
    Class: rviz_default_plugins/PointCloud2
    Color Transformer: FlatColor
    Flat Color:
      R: 0.0
      G: 1.0
      B: 1.0
    Enabled: true
    Name: Cluster 4
    Queue Size: 10
    Selectable: true
    Size (Pixels): 3
    Style: Points
    Topic: /cw1_cloud/cloud_cluster4
    Unreliable: false
    Value: true
  - Alpha: 1
    Class: rviz_default_plugins/PointCloud2
    Color Transformer: FlatColor
    Flat Color:
