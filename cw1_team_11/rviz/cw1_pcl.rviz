Panels:
- Class: rviz_common/Displays
  Name: Displays
- Class: rviz_common/Selection
  Name: Selection
- Class: rviz_common/Tool Properties
  Name: Tool Properties
- Class: rviz_common/Views
  Name: Views
Visualization Manager:
  Class: ""
  Displays:
  - Alpha: 1
    Class: rviz_default_plugins/PointCloud2
    Color Transformer: RGB8
    Enabled: true
    Name: RawCloud
    Queue Size: 10
    Selectable: true
    Size (Pixels): 1
    Style: Points
    Topic: /r200/camera/depth_registered/points
    Unreliable: false
    Value: true
  - Alpha: 1
    Class: rviz_default_plugins/PointCloud2
    Color Transformer: FlatColor
    Flat Color:
      R: 1.0
      G: 1.0
      B: 1.0
    Enabled: true
    Name: Cloud (post-voxel)
    Queue Size: 10
    Selectable: true
    Size (Pixels): 2
    Style: Points
    Topic: /cw1_cloud/cloud
    Unreliable: false
    Value: true
  - Alpha: 1
    Class: rviz_default_plugins/PointCloud2
    Color Transformer: FlatColor
    Flat Color:
      R: 0.0
      G: 1.0
      B: 0.0
    Enabled: true
    Name: Passthrough
    Queue Size: 10
    Selectable: true
    Size (Pixels): 2
    Style: Points
    Topic: /cw1_cloud/cloud_passthrough
    Unreliable: false
    Value: true
  - Alpha: 1
    Class: rviz_default_plugins/PointCloud2
    Color Transformer: FlatColor
    Flat Color:
      R: 0.0
      G: 0.6
      B: 1.0
    Enabled: true
    Name: Outlier Removed
    Queue Size: 10
    Selectable: true
    Size (Pixels): 2
    Style: Points
    Topic: /cw1_cloud/cloud_outlier
    Unreliable: false
    Value: true
  - Alpha: 1
    Class: rviz_default_plugins/PointCloud2
