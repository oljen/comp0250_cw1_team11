    Flat Color:
      R: 0.0
      G: 1.0
      B: 0.4
    Enabled: true
    Name: Cluster 6
    Queue Size: 10
    Selectable: true
    Size (Pixels): 3
    Style: Points
    Topic: /cw1_cloud/cloud_cluster6
    Unreliable: false
